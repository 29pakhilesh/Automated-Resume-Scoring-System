# Copy to .env and adjust. Safe deploy defaults: no run history, no sensitive blobs in DB.

# DATABASE_URL=sqlite+aiosqlite:///...  # optional; defaults under backend/data/

# Persist scoring rows (scores + slim payload). Default in code is false.
# PERSIST_SCORING_RUNS=true

# When true, stores JD excerpt, original filename, and full scoring JSON in the row.
# Default in code is false (recommended for production).
# STORE_SCORING_SENSITIVE_CONTENT_IN_DB=true
